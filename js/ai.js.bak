import { getSettings, getHistory, saveHistory } from './storage.js';
import { generateId, formatTime, renderMarkdown } from './utils.js';

let chatHistory = getHistory();
let abortController = null;
let isGenerating = false;

export function initAI() {
    renderChatHistory();
    
    const input = document.getElementById('chat-input');
    const sendBtn = document.getElementById('btn-send-chat');
    const stopBtn = document.getElementById('btn-stop-chat');

    sendBtn.addEventListener('click', handleSend);
    stopBtn.addEventListener('click', handleStop);

    input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            handleSend();
        }
    });
    
    // Delegate copy clicks
    document.getElementById('chat-container').addEventListener('click', (e) => {
        const copyBtn = e.target.closest('.copy-btn');
        if (copyBtn) {
            const textToCopy = copyBtn.dataset.content;
            navigator.clipboard.writeText(textToCopy).then(() => {
                const icon = copyBtn.querySelector('i');
                icon.setAttribute('data-lucide', 'check-circle-2');
                icon.style.color = '#4ade80';
                window.lucide.createIcons();
                setTimeout(() => {
                    icon.setAttribute('data-lucide', 'copy');
                    icon.style.color = '';
                    window.lucide.createIcons();
                }, 2000);
            });
        }
    });
}

export function renderChatHistory() {
    chatHistory = getHistory();
    const container = document.getElementById('chat-container');
    container.innerHTML = '';
    
    if (chatHistory.length === 0) {
        container.innerHTML = `
            <div style="height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0.5; text-align: center;">
                <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--glass-bg); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                    <i data-lucide="bot" style="width: 32px; height: 32px; color: var(--primary-color);"></i>
                </div>
                <h2>Welcome to SÈNZY AI</h2>
                <p style="max-width: 300px; margin-top: 8px; font-size: 0.875rem;"><h2>Selamat Datang di SÈNZY AI</h2>
<p style="max-width: 300px; margin-top: 8px; font-size: 0.875rem;">
Asisten AI cerdas yang siap menemani percakapan dan membantu berbagai kebutuhanmu.
</p>.</p>
            </div>
        `;
        if (window.lucide) window.lucide.createIcons();
        return;
    }

    chatHistory.forEach(msg => {
        container.appendChild(createMessageElement(msg));
    });
    
    if (window.lucide) window.lucide.createIcons();
    scrollToBottom();
}

function createMessageElement(msg) {
    const div = document.createElement('div');
    div.className = `message-wrapper ${msg.role === 'user' ? 'user' : 'ai'}`;
    div.id = `msg-${msg.id}`;
    
    const time = formatTime(msg.timestamp);
    const sender = msg.role === 'user' ? 'You' : 'SÈNZY AI';
    const icon = msg.role === 'ai' ? '<i data-lucide="bot" style="width:12px;height:12px;"></i>' : '';
    
    let contentHtml = '';
    let copyButtonHtml = '';
    if (msg.role === 'user') {
        // Plain text for user, keep line breaks
        contentHtml = msg.content.replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\\n/g, '<br>');
    } else {
        // Markdown for AI
        contentHtml = renderMarkdown(msg.content);
        // Escape content for data attribute to allow copying original markdown
        const escapedContent = encodeURIComponent(msg.content);
        copyButtonHtml = `<button class="copy-btn" data-content="${decodeURIComponent(escapedContent)}" title="Copy message"><i data-lucide="copy" style="width:14px;height:14px;"></i></button>`;
    }

    div.innerHTML = `
        <div class="message-meta">
            ${icon} <span>${sender}</span> <span>•</span> <span>${time}</span>
        </div>
        <div class="message-bubble ${msg.role === 'ai' ? 'markdown-body' : ''}">
            ${copyButtonHtml}
            <div class="message-content">${contentHtml}</div>
        </div>
    `;
    return div;
}

function scrollToBottom() {
    const container = document.getElementById('chat-container');
    container.scrollTop = container.scrollHeight;
}

async function handleSend() {
    if (isGenerating) return;
    
    const settings = getSettings();
    if (!settings.apiKey) {
        alert("Please set your Gemini API Key in Settings first.");
        document.getElementById('settings-modal').classList.remove('hidden');
        return;
    }

    const inputEl = document.getElementById('chat-input');
    const text = inputEl.value.trim();
    if (!text) return;

    // Reset input
    inputEl.value = '';
    inputEl.style.height = 'auto';
    inputEl.dispatchEvent(new Event('input')); // Update button state
    
    // Add user message
    const userMsg = { id: generateId(), role: 'user', content: text, timestamp: Date.now() };
    chatHistory.push(userMsg);
    saveHistory(chatHistory);
    
    // Re-render chat
    if (chatHistory.length === 1) {
        document.getElementById('chat-container').innerHTML = ''; // clear welcome
    }
    const container = document.getElementById('chat-container');
    container.appendChild(createMessageElement(userMsg));
    
    // Add AI loading placeholder
    const aiId = generateId();
    const aiPlaceholder = document.createElement('div');
    aiPlaceholder.className = 'message-wrapper ai';
    aiPlaceholder.id = `msg-${aiId}`;
    aiPlaceholder.innerHTML = `
        <div class="message-meta">
            <i data-lucide="bot" style="width:12px;height:12px;"></i> <span>SÈNZY AI</span> <span>•</span> <span>${formatTime(Date.now())}</span>
        </div>
        <div class="message-bubble">
            <div class="typing-indicator"><span></span><span></span><span></span></div>
        </div>
    `;
    container.appendChild(aiPlaceholder);
    if (window.lucide) window.lucide.createIcons();
    scrollToBottom();

    // Toggle UI state
    isGenerating = true;
    document.getElementById('btn-send-chat').classList.add('hidden');
    document.getElementById('btn-stop-chat').classList.remove('hidden');

    abortController = new AbortController();

    try {
        await callGeminiAPI(text, aiId, settings);
    } catch (error) {
        if (error.name === 'AbortError') {
            console.log('Generation stopped by user');
        } else {
            console.error('API Error:', error);
            updateAiMessage(aiId, `⚠️ **Error:** ${error.message}. Please check your API key and connection.`, true);
        }
    } finally {
        isGenerating = false;
        document.getElementById('btn-send-chat').classList.remove('hidden');
        document.getElementById('btn-stop-chat').classList.add('hidden');
        abortController = null;
    }
}

function handleStop() {
    if (abortController) {
        abortController.abort();
    }
}

async function callGeminiAPI(newUserText, aiMessageId, settings) {
    // Prepare history for OpenAI/DeepSeek format
    const messages = [
        { role: 'system', content: settings.systemPrompt }
    ];
    chatHistory.slice(0, -1).forEach(msg => {
        messages.push({
            role: msg.role === 'user' ? 'user' : 'assistant',
            content: msg.content
        });
    });
    messages.push({ role: 'user', content: newUserText });

    const systemPrompt = `
Kamu adalah SÈNZY AI, asisten AI pribadi milik Sen.
Selalu gunakan Bahasa Indonesia.
Jangan pernah mengaku sebagai Claude, Anthropic, ChatGPT, OpenAI, Gemini, atau model AI lainnya.
Jika ditanya siapa pembuatmu, jawab bahwa kamu dikembangkan oleh Sen.
Jawab dengan gaya santai, elegan, natural,kurangi mengatakan halo,jangan pernah menggunakan kata kapital, dan tidak kaku.

User: ${newUserText}
`;

let endpoint = `https://api.azbry.com/api/ai/claude?q=${encodeURIComponent(systemPrompt)}`;
    
    // Fallback to Gemini if the user put a Gemini key in settings
    let isGemini = settings.apiKey && settings.apiKey.startsWith('AQ');
    
    if (isGemini) {
        endpoint = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:streamGenerateContent?alt=sse&key=${settings.apiKey}`;
    }

    let requestOptions = {
        signal: abortController.signal
    };

    if (isGemini) {
        const geminiContents = chatHistory.slice(0, -1).map(msg => ({
            role: msg.role === 'user' ? 'user' : 'model',
            parts: [{ text: msg.content }]
        }));
        geminiContents.push({ role: 'user', parts: [{ text: newUserText }] });
        
        requestOptions.method = 'POST';
        requestOptions.headers = { 'Content-Type': 'application/json' };
        requestOptions.body = JSON.stringify({
            contents: geminiContents,
            systemInstruction: { parts: [{ text: settings.systemPrompt }] }
        });
    } else {
        requestOptions.method = 'GET';
        // Note: The Azbry endpoint doesn't need API keys or auth headers as per instructions
    }

    let response;
    let retries = 3;
    let delay = 1000;

    for (let i = 0; i < retries; i++) {
        try {
            response = await fetch(endpoint, requestOptions);

            if (response.status === 429 && i < retries - 1) {
                await new Promise(r => setTimeout(r, delay));
                delay *= 2;
                continue;
            }
            
            if (!response.ok) {
                const errText = await response.text().catch(()=>'');
                throw new Error(`HTTP ${response.status} ${response.statusText} - ${errText.substring(0, 50)}`);
            }
            break;
        } catch (error) {
            if (error.name === 'AbortError') throw error;
            if (i === retries - 1) throw error;
            await new Promise(r => setTimeout(r, delay));
            delay *= 2;
        }
    }

    const contentType = response.headers.get('content-type') || '';
    let fullResponse = '';

    if (isGemini) {
        // Stream parsing for Gemini
        const reader = response.body.getReader();
        const decoder = new TextDecoder("utf-8");
        let buffer = '';

        while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            
            buffer += decoder.decode(value, { stream: true });
            const lines = buffer.split('\n');
            buffer = lines.pop(); // Keep incomplete line
            
            for (const line of lines) {
                if (line.trim() === '') continue;
                if (line.startsWith('data: ')) {
                    const dataStr = line.slice(6).trim();
                    if (dataStr === '[DONE]') continue;
                    
                    try {
                        const data = JSON.parse(dataStr);
                        const chunkText = data.candidates?.[0]?.content?.parts?.[0]?.text;
                        
                        if (chunkText) {
                            fullResponse += chunkText;
                            updateAiMessage(aiMessageId, fullResponse, false);
                            if (settings.typingSpeed > 0) {
                                await new Promise(r => setTimeout(r, settings.typingSpeed));
                            }
                        }
                    } catch (e) {}
                }
            }
        }
    } else {
        // Handle Azbry JSON response
        let data;
        let responseBodyText = '';
        try {
            responseBodyText = await response.text();
            data = JSON.parse(responseBodyText);
        } catch (e) {}

        if (data && data.status === true) {
    fullResponse = data.result;
} else if (data && data.message) {
    fullResponse = data.message;
} else {
    fullResponse = `HTTP ${response.status}`;
}
        
        if (settings.typingSpeed > 0) {
            let currentText = '';
            for (let i = 0; i < fullResponse.length; i++) {
                currentText += fullResponse[i];
                updateAiMessage(aiMessageId, currentText, false);
                await new Promise(r => setTimeout(r, Math.min(settings.typingSpeed, 10)));
            }
        } else {
            updateAiMessage(aiMessageId, fullResponse, false);
        }
    }

    // Finished
    updateAiMessage(aiMessageId, fullResponse, true);
    
    // Save to history
    chatHistory.push({ id: aiMessageId, role: 'ai', content: fullResponse, timestamp: Date.now() });
    saveHistory(chatHistory);
}

function updateAiMessage(id, text, isFinal) {
    const el = document.getElementById(`msg-${id}`);
    if (!el) return;
    
    const bubble = el.querySelector('.message-bubble');
    
    // Render markdown
    let html = renderMarkdown(text);
    
    // If not final and still typing, append cursor
    if (!isFinal) {
        html += '<span style="display:inline-block; width:6px; height:14px; background:var(--text-primary); animation: blink 1s infinite; vertical-align: middle; margin-left: 4px;"></span>';
    }
    
    // Always update the content div inside bubble
    let contentDiv = bubble.querySelector('.message-content');
    if (!contentDiv) {
        bubble.innerHTML = `<div class="message-content"></div>`;
        contentDiv = bubble.querySelector('.message-content');
        bubble.classList.add('markdown-body');
    }
    
    contentDiv.innerHTML = html;
    
    // Re-attach copy button if final
    if (isFinal) {
        const escapedContent = encodeURIComponent(text);
        const copyBtn = `<button class="copy-btn" data-content="${decodeURIComponent(escapedContent)}" title="Copy message"><i data-lucide="copy" style="width:14px;height:14px;"></i></button>`;
        if (!bubble.querySelector('.copy-btn')) {
            bubble.insertAdjacentHTML('afterbegin', copyBtn);
            if (window.lucide) window.lucide.createIcons();
        }
    }
    
    scrollToBottom();
}
